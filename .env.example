# Bind address for the Axum app-server.
APP_SERVER_BIND_ADDR="0.0.0.0:3000"

# Optional explicit public URL for browser-origin validation and same-origin API bootstrap.
VITE_APP_URL="http://localhost:3000"

# Required for durable workshop sessions in production.
DATABASE_URL="postgres://USER:PASSWORD@HOST:5432/DBNAME"

# Optional alternative to DATABASE_URL for mounted secret-file workflows.
DATABASE_URL_FILE="/var/run/secrets/dragon-shift/DATABASE_URL"

# Required in production: explicit allowlist for HTTP and WebSocket origins.
ALLOWED_ORIGINS="https://dragon-shift.example.com"

# Optional session code prefix override.
RUST_SESSION_CODE_PREFIX="9"

# Optional: trust X-Forwarded-For for rate-limit identity only behind a trusted proxy.
TRUST_X_FORWARDED_FOR="false"

# Optional browser-side Gemini key for sprite generation.
VITE_GEMINI_API_KEY="MY_GEMINI_API_KEY"
